{
  "providers": {
    "openrouter": {
      "apiKey": "YOUR_OPENROUTER_API_KEY_HERE"
    }
  },
  "agents": {
    "defaults": {
      "model": "anthropic/claude-sonnet-4-5"
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "token": "YOUR_TELEGRAM_BOT_TOKEN_HERE",
      "allowFrom": ["YOUR_TELEGRAM_USER_ID_HERE"]
    }
  },
  "tools": {
    "restrictToWorkspace": true,
    "web": {
      "search": {
        "apiKey": ""
      }
    }
  }
}
